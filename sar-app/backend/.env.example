# PostgreSQL
DATABASE_URL=postgresql+psycopg2://sar:sar@db:5432/sar

# Auth
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Anthropic API key — required for vision + translation analysis
ANTHROPIC_API_KEY=sk-ant-...

# Vision model used for image captioning / landmark / motion analysis
VISION_MODEL=claude-opus-4-7

# File storage
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=20

# CORS
FRONTEND_ORIGIN=http://localhost:5173
